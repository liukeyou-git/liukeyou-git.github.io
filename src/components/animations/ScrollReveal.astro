---
// Pure Astro scroll-reveal that works in MDX without client: directive
interface Props {
  delay?: number;
  direction?: 'up' | 'down' | 'left' | 'right';
}

const { delay = 0, direction = 'up' } = Astro.props;
const dirMap = { up: '0,60,0', down: '0,-60,0', left: '60,0,0', right: '-60,0,0' };
const initial = dirMap[direction];
---

<div
  class="scroll-reveal"
  data-delay={delay}
  data-initial={initial}
  style="opacity: 0; transform: translate3d(var(--sr-x, 0), var(--sr-y, 60px), 0);"
>
  <slot />
</div>

<script>
  function initReveals() {
    const els = document.querySelectorAll<HTMLElement>('.scroll-reveal');
    if (els.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = parseFloat(el.dataset.delay || '0');
            const [x, y] = (el.dataset.initial || '0,60,0').split(',').map(Number);

            el.style.setProperty('--sr-x', `${x}px`);
            el.style.setProperty('--sr-y', `${y}px`);
            el.style.transition = `opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) ${delay}s, transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) ${delay}s`;
            el.style.opacity = '1';
            el.style.transform = 'translate3d(0, 0, 0)';

            observer.unobserve(el);
          }
        }
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    for (const el of els) {
      observer.observe(el);
    }
  }

  // Run on load
  initReveals();
  // Also observe after Astro page transitions
  document.addEventListener('astro:after-swap', initReveals);
</script>
