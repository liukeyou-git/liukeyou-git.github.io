---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../components/animations/ScrollReveal.astro';
import FilterablePostList from '../../components/blog/FilterablePostList';
import { getCollection } from 'astro:content';

const mdxPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const initialPosts = mdxPosts.map((post) => ({
  id: post.id,
  type: 'mdx' as const,
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  date: post.data.publishedAt.toISOString(),
  href: `/blog/${post.id}`,
  cover: post.data.cover,
}));
---

<BaseLayout title="Blog — liukeyou" description="技术文章和思考">
  <div class="mx-auto max-w-5xl px-6 pb-24">
    <ScrollReveal>
      <h1 class="text-4xl sm:text-5xl font-black gradient-text mb-4">Blog</h1>
      <p class="text-text-secondary mb-10">
        共 {mdxPosts.length}+ 篇文章，持续更新中。
      </p>
    </ScrollReveal>

    <FilterablePostList client:load initialPosts={initialPosts} />
  </div>
</BaseLayout>
