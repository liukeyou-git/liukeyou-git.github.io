---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/blog/TableOfContents';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { slug: post.id },
  }));
}

const { slug } = Astro.props as { slug: string };
const postImport = await import(`../../content/blog/${slug}.mdx`);

const formatDate = (date: Date) => {
  return new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const { Content, frontmatter } = postImport;
---

<BaseLayout title={`${frontmatter.title} — liukeyou`} description={frontmatter.description}>
  <TableOfContents client:load />
  
  <article class="mx-auto max-w-3xl px-6 pb-24">
    <header class="mb-12">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        {frontmatter.tags.map((tag: string) => (
          <span
            key={tag}
            class="px-3 py-1 text-xs rounded-full bg-accent/10 text-accent-hover"
          >
            {tag}
          </span>
        ))}
      </div>
      
      <h1 class="text-4xl sm:text-5xl font-black text-text-primary mb-4 leading-tight">
        {frontmatter.title}
      </h1>
      
      <p class="text-text-secondary text-lg mb-6">
        {frontmatter.description}
      </p>
      
      <div class="flex items-center gap-4 text-sm text-text-secondary">
        <span>{formatDate(frontmatter.publishedAt)}</span>
        {frontmatter.updatedAt && (
          <span class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
              <path d="M3 3v5h5"></path>
              <path d="M16 5l4 4"></path>
              <path d="M20 16v5h-5"></path>
            </svg>
            更新于 {formatDate(frontmatter.updatedAt)}
          </span>
        )}
      </div>
    </header>
    
    <div class="prose">
      <Content />
    </div>
    
    <footer class="mt-16 pt-8 border-t border-white/10">
      <div class="flex items-center justify-between">
        <p class="text-sm text-text-secondary">
          作者：liukeyou
        </p>
        <div class="flex items-center gap-4">
          <button class="flex items-center gap-2 px-4 py-2 rounded-lg bg-bg-card text-text-secondary hover:text-text-primary transition-colors text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
            点赞
          </button>
          <button class="flex items-center gap-2 px-4 py-2 rounded-lg bg-bg-card text-text-secondary hover:text-text-primary transition-colors text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
            分享
          </button>
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>