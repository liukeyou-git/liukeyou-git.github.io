---
import BaseLayout from '../layouts/BaseLayout.astro';
import ParticleField from '../components/animations/ParticleField';
import ScrollReveal from '../components/animations/ScrollReveal.astro';

const posts = [];
---

<BaseLayout title="liukeyou — Developer & Creator" description="一个热爱技术、写作和创造的个人博客">
  <ParticleField client:load />

  <div class="relative z-10">
    <!-- Hero -->
    <section class="mx-auto max-w-5xl px-6 pt-16 pb-24 sm:pt-28 sm:pb-36">
      <ScrollReveal>
        <div class="max-w-2xl">
          <p class="text-accent-hover text-sm font-mono mb-4 tracking-wider">
            👋 Hello, I'm
          </p>
          <h1 class="text-5xl sm:text-7xl font-black leading-[1.05] mb-6">
            <span class="gradient-text">liukeyou</span>
          </h1>
          <p class="text-lg sm:text-xl text-text-secondary leading-relaxed mb-8">
            一个热爱技术的开发者。<br />
            在这里记录我的思考和探索，分享技术心得与工作复盘。
          </p>

          <div class="flex items-center gap-4">
            <a
              href="/about"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-accent text-white font-medium text-sm hover:bg-accent-hover transition-all hover:scale-105 active:scale-95"
            >
              了解更多
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
            <a
              href="https://github.com/liukeyou-git"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-white/10 text-text-secondary text-sm hover:text-text-primary hover:border-white/20 transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
          </div>
        </div>
      </ScrollReveal>
    </section>
  </div>
</BaseLayout>